{
  "expo": {
    "name": "GreenLink Farmer",
    "slug": "greenlink-farmer",
    "version": "1.18.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d5a4d"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.greenlink.farmer",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSCameraUsageDescription": "GreenLink a besoin d'accéder à la caméra pour scanner les QR codes et photographier les parcelles.",
        "NSLocationWhenInUseUsageDescription": "GreenLink a besoin de votre position pour géolocaliser vos photos et parcelles."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2d5a4d"
      },
      "package": "com.greenlink.farmer",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2d5a4d"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GreenLink a besoin de votre position pour localiser vos parcelles."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GreenLink a besoin d'accéder à la caméra pour photographier vos parcelles."
        }
      ]
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2d5a4d",
      "androidMode": "default",
      "androidCollapsedTitle": "GreenLink"
    },
    "extra": {
      "eas": {
        "projectId": "69cdf51e-6916-433e-99ed-bfdc2e852057"
      }
    },
    "owner": "treckadzo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/69cdf51e-6916-433e-99ed-bfdc2e852057"
    }
  }
}
