{
  "expo": {
    "name": "GreenLink Farmer",
    "slug": "greenlink-farmer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d5a4d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.greenlink.farmer",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GreenLink utilise l'appareil photo pour prendre des photos de vos parcelles et r\u00e9coltes.",
        "NSLocationWhenInUseUsageDescription": "GreenLink utilise votre position pour localiser vos parcelles.",
        "NSPhotoLibraryUsageDescription": "GreenLink utilise votre galerie pour s\u00e9lectionner des photos de vos parcelles.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2d5a4d"
      },
      "package": "com.greenlink.farmer",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "GreenLink utilise l'appareil photo pour photographier vos parcelles."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GreenLink utilise votre position pour localiser vos parcelles."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2d5a4d",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GreenLink acc\u00e8de \u00e0 vos photos pour les ajouter \u00e0 vos parcelles."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "greenlink-farmer"
      }
    },
    "owner": "treckadzo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/greenlink-farmer",
      "fallbackToCacheTimeout": 30000
    }
  }
}