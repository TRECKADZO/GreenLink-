{
  "expo": {
    "name": "GreenLink Agritech",
    "slug": "greenlink-farmer",
    "version": "1.56.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d5a4d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.greenlink.farmer",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "GreenLink a besoin d'acc\u00e9der \u00e0 la cam\u00e9ra pour photographier les parcelles et preuves de v\u00e9rification.",
        "NSLocationWhenInUseUsageDescription": "GreenLink a besoin de votre position pour g\u00e9olocaliser vos photos et parcelles."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#2d5a4d"
      },
      "package": "com.greenlink.farmer",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2d5a4d"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GreenLink a besoin de votre position pour localiser vos parcelles."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GreenLink a besoin d'acc\u00e9der \u00e0 la cam\u00e9ra pour photographier vos parcelles."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "GreenLink a besoin de la cam\u00e9ra pour prendre des photos de vos parcelles."
        }
      ],
      "./plugins/removeMediaPermissions",
      "expo-font"
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2d5a4d",
      "androidMode": "default",
      "androidCollapsedTitle": "GreenLink"
    },
    "extra": {
      "eas": {
        "projectId": "69cdf51e-6916-433e-99ed-bfdc2e852057"
      }
    },
    "owner": "treckadzo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/69cdf51e-6916-433e-99ed-bfdc2e852057"
    }
  }
}